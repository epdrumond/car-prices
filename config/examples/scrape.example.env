# Optional env for `python -m discovery.run --source http_scrape`
# Do not commit real targets. Copy lines into your shell or a local file under config/local/.

# Required for a real fetch (one public page, https recommended):
# export SCRAPE_URL="https://example.com/"

# Built-in defaults (extremely conservative):
#   SCRAPE_MAX_REQUESTS=1
#   SCRAPE_MIN_DELAY_S=5.0
#   SCRAPE_MAX_BYTES_SAVED=150000
#   SCRAPE_TIMEOUT=20
#   SCRAPE_USER_AGENT="..."
